rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Colección de Empleados (Web y Tablet)
    match /employees/{docId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'active',
          'kioskEnabled',
          'lastAction',
          'lastTimestampServer',
          'department',
          'hourlyRate',
          'employeeId',
          'photoUrl',
          'locationId',
          'locationGroupId',
          'phone',
          'dateOfBirth',
          'addressLine1',
          'addressLine2',
          'city',
          'state',
          'postcode',
          'country',
          'emergencyContactName',
          'emergencyContactPhone',
          'passportNumber',
          'passportUrl',
          'passportFileName',
          'visaUrl',
          'visaFileName',
          'visaExpiry',
          'startDate',
          'endDate',
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.employeeId is string &&
        request.resource.data.active is bool &&
        (
          !('kioskEnabled' in request.resource.data) ||
          request.resource.data.kioskEnabled is bool
        ) &&
        (
          !('locationId' in request.resource.data) ||
          request.resource.data.locationId is string
        ) &&
        (
          !('locationGroupId' in request.resource.data) ||
          request.resource.data.locationGroupId is string
        ) &&
        (
          !('lastAction' in request.resource.data) ||
          request.resource.data.lastAction in ['check_in', 'check_out', 'none']
        );

      // Tablet: solo lastAction + lastTimestampServer
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastAction', 'lastTimestampServer']) &&
        request.resource.data.lastAction in ['check_in', 'check_out', 'none'];

      // Web admin: edición completa del empleado
      allow update: if
        request.resource.data.keys().hasAll([
          'name',
          'email',
          'employeeId',
          'department',
          'hourlyRate',
          'active',
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.employeeId is string &&
        request.resource.data.active is bool &&
        (
          !('kioskEnabled' in request.resource.data) ||
          request.resource.data.kioskEnabled is bool
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'employeeId',
          'name',
          'email',
          'department',
          'hourlyRate',
          'photoUrl',
          'active',
          'kioskEnabled',
          'locationId',
          'locationGroupId',
          'phone',
          'dateOfBirth',
          'addressLine1',
          'addressLine2',
          'city',
          'state',
          'postcode',
          'country',
          'emergencyContactName',
          'emergencyContactPhone',
          'passportNumber',
          'passportUrl',
          'passportFileName',
          'visaUrl',
          'visaFileName',
          'visaExpiry',
          'startDate',
          'endDate',
        ]);

      allow delete: if request.auth != null;
    }

    // 2. Colección de Registros de Asistencia (Tablet y Web Admin)
    match /attendance_records/{recordId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly([
          'employeeId',
          'employeeNameSnapshot',
          'employeeEmailSnapshot',
          'type',
          'timestampServer',
          'source',
          'photoCaptured',
          'photoPath',
          'photoUrl',
          'locationId',
          'locationNameSnapshot',
          'locationCitySnapshot',
          'latitude',
          'longitude',
          'geoAccuracy',
          'geoCapturedAt',
          'geoAddress',
          'breakWaived',
        ]) &&
        request.resource.data.employeeId is string &&
        request.resource.data.employeeNameSnapshot is string &&
        request.resource.data.employeeEmailSnapshot is string &&
        request.resource.data.type in ['check_in', 'check_out'] &&
        request.resource.data.source in [
          'expo-app',
          'web-admin-manual-checkout',
          'web-admin-manual',
        ] &&
        request.resource.data.photoCaptured is bool &&
        request.resource.data.photoPath is string &&
        request.resource.data.photoUrl is string &&
        (
          !('locationId' in request.resource.data) ||
          request.resource.data.locationId is string
        ) &&
        (
          !('locationNameSnapshot' in request.resource.data) ||
          request.resource.data.locationNameSnapshot is string
        ) &&
        (
          !('locationCitySnapshot' in request.resource.data) ||
          request.resource.data.locationCitySnapshot is string
        ) &&
        (
          !('latitude' in request.resource.data) ||
          request.resource.data.latitude is number
        ) &&
        (
          !('longitude' in request.resource.data) ||
          request.resource.data.longitude is number
        ) &&
        (
          !('geoAccuracy' in request.resource.data) ||
          request.resource.data.geoAccuracy is number
        ) &&
        (
          !('geoCapturedAt' in request.resource.data) ||
          request.resource.data.geoCapturedAt is string
        ) &&
        (
          !('geoAddress' in request.resource.data) ||
          request.resource.data.geoAddress is string
        ) &&
        (
          !('breakWaived' in request.resource.data) ||
          request.resource.data.breakWaived is bool
        );

      allow update, delete: if request.auth != null;
    }

    // 3. Colección de Turnos (Agenda)
    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Solicitudes de Permisos y Vacaciones
    match /leave_requests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // 5. Configuración global (zona horaria, moneda)
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 6. Continental Inspect — inspecciones de carga (AKE/PMC)
    match /cargo_inspections/{inspectionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // 7. Portal clientes B2B (forwarders / aduanas) — solo admin autenticado
    match /portal_clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    // 8. Sedes / ubicaciones de empleados
    match /locations/{locationId} {
      allow read, write: if request.auth != null;
    }

    // 8b. Departamentos
    match /departments/{departmentId} {
      allow read, write: if request.auth != null;
    }

    // 9. Grupos de sedes (multi-warehouse access)
    match /location_groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    // 10. Dispositivos kiosk — solo Admin SDK (API routes)
    match /kiosk_devices/{deviceId} {
      allow read, write: if false;
    }

    // 11. Bandeja de notificaciones (empleado)
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.recipientEmail == request.auth.token.email;

      allow create: if request.auth != null
        && request.resource.data.recipientEmail == request.auth.token.email
        && request.resource.data.audience == 'employee'
        && request.resource.data.read == false
        && request.resource.data.dismissed == false;

      allow update: if request.auth != null
        && resource.data.recipientEmail == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['read', 'dismissed']);
    }

    // 12. Preferencias de bandeja admin (alertas operativas dismiss)
    match /notification_preferences/{prefsId} {
      allow read: if request.auth != null
        && (
          resource == null
          || resource.data.recipientEmail == request.auth.token.email
        );

      allow create, update: if request.auth != null
        && request.resource.data.recipientEmail == request.auth.token.email;
    }

    // 13. Justificaciones de asistencia — solo Admin SDK (API routes)
    match /attendance_justifications/{justificationId} {
      allow read, write: if false;
    }

    // 14. Anuncios broadcast — solo Admin SDK (API routes)
    match /announcements/{announcementId} {
      allow read, write: if false;
    }

    // 15. Plantillas de rol admin — lectura autenticada; escritura solo Admin SDK
    match /admin_roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 16. Auditoría — solo Admin SDK (API routes); lectura bloqueada en cliente
    match /audit_logs/{logId} {
      allow read, write: if false;
    }

    // Bloqueo de seguridad global por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
