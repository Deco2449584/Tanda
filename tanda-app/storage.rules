rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /attendance/{employeeId}/{year}/{month}/{fileName} {
      allow read: if true;
      allow write: if
        employeeId is string &&
        employeeId.size() > 0 &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
