rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function attendanceRecordKeys() {
      return [
        'employeeId',
        'employeeNameSnapshot',
        'employeeEmailSnapshot',
        'type',
        'timestampServer',
        'source',
        'photoCaptured',
        'photoPath',
        'photoUrl',
      ];
    }

    function isValidAttendanceCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly(attendanceRecordKeys()) &&
        data.employeeId is string &&
        data.employeeNameSnapshot is string &&
        data.employeeEmailSnapshot is string &&
        data.type in ['check_in', 'check_out'] &&
        data.photoCaptured is bool &&
        data.photoPath is string &&
        data.photoUrl is string &&
        (
          (data.source == 'expo-app') ||
          (data.source == 'web-admin-manual-checkout' && data.photoCaptured == false)
        );
    }

    match /employees/{employeeId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'active']) &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.active is bool;

      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastAction',
          'lastTimestampServer',
        ]) &&
        (
          !('lastAction' in request.resource.data) ||
          request.resource.data.lastAction in ['check_in', 'check_out', 'none']
        ) ||
        (
          request.resource.data.keys().hasAll([
            'employeeId',
            'name',
            'email',
            'department',
            'hourlyRate',
          ]) &&
          request.resource.data.name is string &&
          request.resource.data.email is string
        );

      allow delete: if false;
    }

    match /attendance_records/{recordId} {
      allow read: if true;
      allow create: if isValidAttendanceCreate();
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'type',
          'timestampServer',
        ]) &&
        request.resource.data.type in ['check_in', 'check_out'];
      allow delete: if true;
    }

    match /shifts/{shiftId} {
      allow read, write: if true;
    }

    match /leave_requests/{requestId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
